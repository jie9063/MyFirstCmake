{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake -S . -B build -G Ninja -DCMAKE_TOOLCHAIN_FILE=cmake/arm-none-eabi-gcc.cmake -DCMAKE_BUILD_TYPE=Debug"
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake --build build",
      "dependsOn": "CMake: Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "CMake: Flash (OpenOCD)",
      "type": "shell",
      "command": "cmake --build build --target flash",
      "dependsOn": "CMake: Build"
    }
  ]
}